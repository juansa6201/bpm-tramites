# ==========================================================================
# .env.example — copiá a .env y completá los valores.
# El archivo .env está en .gitignore y NO debe commitearse.
# ==========================================================================

# --- PostgreSQL (servicio db) ---
POSTGRES_USER=bpm
POSTGRES_PASSWORD=bpm_password
POSTGRES_DB=bpm_tramites
POSTGRES_PORT=5432

# --- Prisma / Backend ---
# Host "db" cuando corre en docker-compose; "localhost" si corrés la API fuera de Docker.
DATABASE_URL=postgresql://bpm:bpm_password@db:5432/bpm_tramites?schema=public
API_PORT=3001
NODE_ENV=development

# --- Auth externos (JWT propio) ---
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# --- Auth internos (Azure Entra ID / MSAL) ---
# AUTH_INTERNAL_MODE=mock  -> usa mock seguro local (default para desarrollo)
# AUTH_INTERNAL_MODE=azure -> valida tokens reales de Azure Entra ID
AUTH_INTERNAL_MODE=mock
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_AUDIENCE=

# --- Email (magic link / OTP / notificaciones) ---
# En desarrollo se puede usar un mock que loguea el link/OTP por consola.
MAIL_MODE=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@bpm-tramites.local

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
WEB_PORT=3000
